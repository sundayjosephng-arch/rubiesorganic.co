# Example environment variables for rubies-backend
# Replace values with your actual configuration
COMPANY_EMAIL=rubiesorganic@gmail.com
EMAIL_APP_PASSWORD=your_google_app_password_here
PORT=5000
# Redis queue (optional — required for worker mode)
REDIS_URL=redis://127.0.0.1:6379
# When set to true, the worker will simulate email delivery by writing files to rubies-backend/fake-emails
SIMULATE_EMAIL=true
# If you prefer to send via SMTP host/port, you can add these as well
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
